# ═══════════════════════════════════════════════════════════════
# Quil - Crime Pump Detection & Trading Bot
# Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Blockchain Explorers ─────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_key
BSCSCAN_API_KEY=your_bscscan_key
SOLSCAN_API_KEY=your_solscan_key

# ── Market Data ──────────────────────────────────────────────
COINGLASS_API_KEY=your_coinglass_key
COINGECKO_API_KEY=your_coingecko_key
BITGET_SKILL_HUB_BASE_URL=https://agenthub.bitget.com/v1/skills

# ── Exchange API Keys (for live trading via CCXT) ────────────
# Only needed if TRADING_MODE=live
BINANCE_API_KEY=
BINANCE_SECRET=
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSPHRASE=
GATE_API_KEY=
GATE_SECRET=
BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET=your_bybit_secret
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# ── Social ───────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=

# ── Database ─────────────────────────────────────────────────
# PostgreSQL (Supabase) — recommended for persistent data
# Get from: Supabase → Connect → Session Pooler → URI
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# SQLite fallback (local dev only, data lost on Railway redeploys)
# DATABASE_URL=sqlite+aiosqlite:///./quil.db

# ── Trading Mode ─────────────────────────────────────────────
# "paper" = simulated trades (default, safe)
# "live"  = real money on exchanges (requires API keys above)
TRADING_MODE=paper

# ── Bot Settings ─────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=30
ALERT_COOLDOWN_MINUTES=15
MIN_CONFIDENCE_ALERT=0.5
MIN_LAYERS_CONFIRMED=2
